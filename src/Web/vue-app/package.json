{
  "name": "vue-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode production",
    "build:check": "vue-tsc --noEmit && vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:a11y": "eslint \"src/components/blocks/renderers/**/*.vue\" \"src/components/forms/**/*.vue\" \"src/components/layouts/PublicLayout.vue\" \"src/components/layouts/AuthenticationLayout.vue\" \"src/components/layouts/items/CookieBanner.vue\" \"src/components/layouts/items/PublicFooter.vue\" \"src/components/navigation/PublicNavbar.vue\" \"src/views/Login.vue\" \"src/views/ForgotPassword.vue\" \"src/views/ResetPassword.vue\" \"src/views/TwoFactor.vue\" \"src/views/public/**/*.vue\" --max-warnings=0",
    "test:a11y": "playwright test -c playwright.a11y.config.ts",
    "lighthouse:a11y": "lighthouse \"${PLAYWRIGHT_BASE_URL:-http://127.0.0.1:5280}\" --only-categories=accessibility --output=json --output-path=./lighthouse-accessibility.json --chrome-flags=\"--headless --no-sandbox\""
  },
  "dependencies": {
    "@kyvg/vue3-notification": "^3.4.0",
    "@microsoft/signalr": "^10.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tiptap/extension-color": "^3.19.0",
    "@tiptap/extension-image": "^3.19.0",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-text-align": "^3.19.0",
    "@tiptap/extension-text-style": "^3.19.0",
    "@tiptap/extension-underline": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@tiptap/vue-3": "^3.19.0",
    "@unhead/vue": "^3.0.3",
    "axios": "^1.13.5",
    "dompurify": "^3.3.2",
    "focus-trap": "^8.2.0",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.3",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "universal-cookie": "^8.0.1",
    "vue": "^3.5.0",
    "vue-draggable-plus": "^0.6.1",
    "vue-i18n": "^11.3.0",
    "vue-material-design-icons": "^5.3.0",
    "vue-router": "^5.0.2",
    "vue3-easy-data-table": "^1.5.47"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.2.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.7.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "globals": "^17.3.0",
    "lighthouse": "^13.2.0",
    "sass": "^1.83.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vite-svg-loader": "^5.1.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.4",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  }
}
